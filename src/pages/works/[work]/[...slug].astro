---
import DocLayout from '../../../layouts/DocLayout.astro';
import TimelineLayout from '../../../layouts/TimelineLayout.astro';
import GalleryLayout from '../../../layouts/GalleryLayout.astro';
import { getWorks, getChapters, extractChapterSlug } from '../../../utils/works';

export async function getStaticPaths() {
  const works = await getWorks();
  const paths = [];
  for (const w of works) {
    const chapters = await getChapters(w.slug);
    for (const c of chapters) {
      const chapterSlug = extractChapterSlug(c.id);
      paths.push({
        params: { work: w.slug, slug: chapterSlug },
        props: { work: w, chapter: c },
      });
    }
  }
  return paths;
}

const { work, chapter } = Astro.props;
const theme = chapter.data.themePalette ?? work.data.defaultThemePalette;
const layoutType = chapter.data.layoutType ?? work.data.defaultLayoutType;
const { Content, headings } = await chapter.render();
const base = import.meta.env.BASE_URL;

const chapters = await getChapters(work.slug);
const curIdx = chapters.findIndex((c) => c.id === chapter.id);
const prev = curIdx > 0 ? chapters[curIdx - 1] : null;
const next = curIdx < chapters.length - 1 ? chapters[curIdx + 1] : null;

function hrefFor(c: typeof chapter | null) {
  if (!c) return '';
  return base + 'works/' + work.slug + '/' + extractChapterSlug(c.id) + '/';
}

let sideNavHtml = `<span class="side-nav-title">《${work.data.title}》</span><ul>`;
chapters.forEach((c, i) => {
  const isActive = c.id === chapter.id;
  sideNavHtml += `<li><a href="${hrefFor(c)}" class="${isActive ? 'active' : ''}">${i + 1}. ${c.data.title}</a></li>`;
});
sideNavHtml += '</ul>';

let pageNavHtml = '<hr style="margin:3rem 0 1.5rem;border:none;border-top:1px solid var(--border-color)" /><nav style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem">';
if (prev) {
  pageNavHtml += '<a href="' + hrefFor(prev) + '" class="btn">← ' + prev.data.title + '</a>';
} else {
  pageNavHtml += '<span style="color:var(--text-muted)">已是第一章</span>';
}
pageNavHtml += '<span></span>';
if (next) {
  pageNavHtml += '<a href="' + hrefFor(next) + '" class="btn btn-primary">' + next.data.title + ' →</a>';
} else {
  pageNavHtml += '<span style="color:var(--text-muted)">已是最后一章</span>';
}
pageNavHtml += '</nav>';
---

{layoutType === 'document' && (
  <DocLayout title={work.data.title} theme={theme} pageTitle={chapter.data.title} description={chapter.data.summary} headings={headings} sideNavHtml={sideNavHtml} backHref={base + 'works/' + work.slug + '/'} workTitle={work.data.title}>
    <article>
      <header style="margin-bottom:2rem">
        <p style="color:var(--text-muted);font-size:0.9em;margin-bottom:0.3em"><a href={base + 'works/' + work.slug + '/'}>← 返回《{work.data.title}》</a></p>
        <h1 style="margin-top:0">{chapter.data.title}</h1>
        {chapter.data.summary && <p style="color:var(--text-muted);font-size:1.05em">{chapter.data.summary}</p>}
        {chapter.data.tags.length > 0 && <div>{chapter.data.tags.map((t) => <span class="tag">{t}</span>)}</div>}
      </header>
      <Content />
      <div class="page-nav" set:html={pageNavHtml} />
    </article>
  </DocLayout>
)}

{layoutType === 'timeline' && (
  <TimelineLayout title={work.data.title} theme={theme} pageTitle={chapter.data.title} description={chapter.data.summary}>
    <header style="margin-bottom:2rem">
      <p style="color:var(--text-muted);font-size:0.9em;margin-bottom:0.3em"><a href={base + 'works/' + work.slug + '/'}>← 返回《{work.data.title}》</a></p>
      <h1 style="margin-top:0">{chapter.data.title}</h1>
      {chapter.data.summary && <p style="color:var(--text-muted);font-size:1.05em">{chapter.data.summary}</p>}
      {chapter.data.tags.length > 0 && <div>{chapter.data.tags.map((t) => <span class="tag">{t}</span>)}</div>}
    </header>
    <Content />
    <div class="page-nav" set:html={pageNavHtml} />
  </TimelineLayout>
)}

{layoutType === 'gallery' && (
  <GalleryLayout title={work.data.title} theme={theme} pageTitle={chapter.data.title} description={chapter.data.summary}>
    <header style="margin-bottom:2rem">
      <p style="color:var(--text-muted);font-size:0.9em;margin-bottom:0.3em"><a href={base + 'works/' + work.slug + '/'}>← 返回《{work.data.title}》</a></p>
      <h1 style="margin-top:0">{chapter.data.title}</h1>
      {chapter.data.summary && <p style="color:var(--text-muted);font-size:1.05em">{chapter.data.summary}</p>}
      {chapter.data.tags.length > 0 && <div>{chapter.data.tags.map((t) => <span class="tag">{t}</span>)}</div>}
    </header>
    <Content />
    <div class="page-nav" set:html={pageNavHtml} />
  </GalleryLayout>
)}
