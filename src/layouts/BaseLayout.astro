---
import '../styles/theme.css';
import { ViewTransitions } from 'astro:transitions';
import SearchBox from '../components/SearchBox.astro';

export interface Props {
  title: string;
  theme: 'ocean' | 'crimson' | 'amber';
  description?: string;
  pageTitle?: string;
}

const { title, theme, description = '', pageTitle } = Astro.props;
const base = import.meta.env.BASE_URL;
const displayTitle = pageTitle ? `${pageTitle} · ${title}` : title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{displayTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="base-url" content={base} />
    <ViewTransitions />
  </head>
  <body class={`theme-${theme}`}>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={base} class="site-title">ACG <span class="accent">Wiki</span></a>
        <nav>
          <a href={base + 'works/'} class="btn">全部作品</a>
          <SearchBox />
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      © ACG Knowledge Wiki · Built with Astro · Pagefind 搜索
    </footer>
  </body>
</html>
