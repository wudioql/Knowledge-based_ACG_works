---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  theme: 'ocean' | 'crimson' | 'amber';
  pageTitle?: string;
  description?: string;
}

const { title, theme, pageTitle, description } = Astro.props;
---

<BaseLayout title={title} theme={theme} pageTitle={pageTitle} description={description}>
  <div class="timeline-wrap">
    <div class="timeline">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .timeline-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.2rem 3rem;
  }
  .timeline {
    position: relative;
    padding-left: 2rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0.6rem;
    width: 3px;
    background: linear-gradient(180deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 3px;
  }
</style>
