---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  theme: 'ocean' | 'crimson' | 'amber' | 'parchment';
  pageTitle?: string;
  description?: string;
  /** 当前章节的大纲（可选：用于右侧 TOC rail / 窄屏弹出层） */
  headings?: { depth: number; text: string; slug?: string }[];
  /** 章节目录 HTML（用于左侧侧栏） */
  chaptersNavHtml?: string;
  /** 返回按钮 href（通常为作品首页） */
  backHref?: string;
  /** 作品标题（展示在返回按钮旁） */
  workTitle?: string;
}

const { title, theme, pageTitle, description, chaptersNavHtml = '', backHref, workTitle } = Astro.props;
---

<BaseLayout title={title} theme={theme} pageTitle={pageTitle} description={description}>
  {/* 窄屏 action bar */}
  <div class="reader-action-bar" aria-label="阅读导航">
    <div class="reader-action-group">
      {backHref && (
        <a href={backHref} class="btn-sm btn-ghost" aria-label="返回作品首页">
          ← <span class="btn-label">{workTitle ? `《${workTitle}》` : '返回'}</span>
        </a>
      )}
      <button class="btn-sm" id="side-nav-toggle" type="button" aria-label="打开章节目录" aria-controls="side-nav">
        ☰ <span class="btn-label">章节</span>
      </button>
    </div>
    <div class="reader-action-group"></div>
  </div>

  <div class="timeline-grid">
    <aside class="side-nav" id="side-nav" aria-label="章节目录">
      <div class="side-nav-header">
        <span class="side-nav-title">章节目录</span>
        <button class="side-nav-close" id="side-nav-close" type="button" aria-label="关闭目录">✕</button>
      </div>
      <div class="side-nav-inner" set:html={chaptersNavHtml} />
    </aside>
    <main class="timeline-main">
      <div class="timeline">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .timeline-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 2rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.2rem 3rem;
  }
  .side-nav {
    position: sticky;
    top: 80px;
    align-self: start;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    font-size: 0.9em;
    scrollbar-width: thin;
  }
  .side-nav::-webkit-scrollbar { width: 6px; }
  .side-nav::-webkit-scrollbar-track { background: transparent; }
  .side-nav::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 999px;
  }
  .side-nav::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }
  .side-nav-header {
    display: none;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border-color);
  }
  .side-nav-title {
    font-weight: 700;
    color: var(--accent-primary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.78em;
  }
  .side-nav-close {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    width: 1.8rem;
    height: 1.8rem;
    cursor: pointer;
    font-size: 0.8em;
    line-height: 1;
  }
  .side-nav-close:hover { color: var(--accent-primary); border-color: var(--accent-primary); }

  .timeline-main {
    min-width: 0;
    padding: 0 0.5rem;
  }
  .timeline {
    position: relative;
    padding-left: 2rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0.6rem;
    width: 3px;
    background: linear-gradient(180deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 3px;
  }

  @media (max-width: 1100px) {
    .timeline-grid {
      grid-template-columns: 180px minmax(0, 1fr);
    }
  }
  @media (max-width: 720px) {
    .timeline-grid {
      grid-template-columns: 1fr;
      padding-top: 1rem;
    }
    .reader-action-bar {
      display: flex;
    }
    .side-nav {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 300px;
      max-width: 85vw;
      max-height: 100vh;
      z-index: 90;
      border-radius: 0 var(--radius) var(--radius) 0;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      padding-top: 1.5rem;
      box-shadow: var(--shadow-hover);
    }
    .side-nav-header {
      display: flex;
    }
    body.side-nav-open .side-nav {
      transform: translateX(0);
    }
  }
</style>
