---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

export interface Props {
  title: string;
  theme: 'ocean' | 'crimson' | 'amber';
  pageTitle?: string;
  description?: string;
  /** 当前章节的大纲，用于右侧 TOC rail */
  headings?: { depth: number; text: string; slug?: string }[];
  /** 章节目录 HTML（包含所有作品章节，支持层级展开） */
  chaptersNavHtml?: string;
  /** 返回按钮 href（通常返回作品首页） */
  backHref?: string;
  /** 作品标题，显示在返回按钮旁 */
  workTitle?: string;
}

const { title, theme, pageTitle, description, headings = [], chaptersNavHtml = '', backHref, workTitle } = Astro.props;
const hasToc = headings.length > 0;
---

<BaseLayout title={title} theme={theme} pageTitle={pageTitle} description={description}>
  {/* 窄屏 action bar（顶部按钮组） */}
  <div class="reader-action-bar" id="reader-action-bar" aria-label="阅读导航">
    <div class="reader-action-group">
      {backHref && (
        <a href={backHref} class="btn-sm btn-ghost" aria-label="返回作品首页">
          ← <span class="btn-label">{workTitle ? `《${workTitle}》` : '返回'}</span>
        </a>
      )}
      <button class="btn-sm" id="side-nav-toggle" type="button" aria-label="打开章节目录" aria-controls="side-nav">
        ☰ <span class="btn-label">章节</span>
      </button>
    </div>
    <div class="reader-action-group">
      {hasToc && (
        <button class="btn-sm" id="toc-toggle" type="button" aria-label="本章目录" aria-controls="toc-popover" aria-expanded="false">
          📑 <span class="btn-label">目录</span>
        </button>
      )}
    </div>
  </div>

  {/* 遮罩层（点击关闭侧栏/弹出层） */}
  <div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

  <div class="doc-grid">
    {/* 章节目录（宽屏显示在左侧，窄屏为抽屉） */}
    <aside class="side-nav" id="side-nav" aria-label="章节目录">
      <div class="side-nav-header">
        <span class="side-nav-title">章节目录</span>
        <button class="side-nav-close" id="side-nav-close" type="button" aria-label="关闭目录">✕</button>
      </div>
      <div class="side-nav-inner" set:html={chaptersNavHtml} />
    </aside>

    {/* 正文 */}
    <main class="doc-main">
      <slot />
    </main>

    {/* 右侧 TOC rail（宽屏） */}
    {hasToc && (
      <div class="toc-col">
        <TableOfContents headings={headings} />
      </div>
    )}
  </div>

  {/* 窄屏 TOC 弹出层 */}
  {hasToc && (
    <div class="toc-popover" id="toc-popover" role="dialog" aria-modal="false" aria-label="本章目录" hidden>
      <div class="toc-rail">
        <TableOfContents headings={headings} mode="popover" />
      </div>
    </div>
  )}
</BaseLayout>

<style>
  .doc-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) 240px;
    gap: 2rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.2rem 3rem;
  }
  .side-nav {
    position: sticky;
    top: 80px;
    align-self: start;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    font-size: 0.9em;
    scrollbar-width: thin;
  }
  .side-nav::-webkit-scrollbar { width: 6px; }
  .side-nav::-webkit-scrollbar-track { background: transparent; }
  .side-nav::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 999px;
  }
  .side-nav::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }

  .side-nav-header {
    display: none;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border-color);
  }
  .side-nav-title {
    font-weight: 700;
    color: var(--accent-primary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.78em;
  }
  .side-nav-close {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    width: 1.8rem;
    height: 1.8rem;
    cursor: pointer;
    font-size: 0.8em;
    line-height: 1;
  }
  .side-nav-close:hover { color: var(--accent-primary); border-color: var(--accent-primary); }

  .doc-main {
    min-width: 0;
    padding: 0 0.5rem;
  }
  .doc-main > :global(article) {
    max-width: 780px;
    margin: 0 auto;
  }
  .toc-col {
    align-self: start;
  }

  /* 响应式 */
  @media (max-width: 1100px) {
    .doc-grid {
      grid-template-columns: 200px minmax(0, 1fr);
    }
    .toc-col { display: none; }
  }
  @media (max-width: 720px) {
    .doc-grid {
      grid-template-columns: 1fr;
      padding-top: 1rem;
    }
    /* 开启顶部 action bar */
    .reader-action-bar {
      display: flex;
    }
    /* 侧栏抽屉（固定，从左滑入） */
    .side-nav {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 300px;
      max-width: 85vw;
      max-height: 100vh;
      z-index: 90;
      border-radius: 0 var(--radius) var(--radius) 0;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      padding-top: 1.5rem;
      box-shadow: var(--shadow-hover);
    }
    .side-nav-header {
      display: flex;
    }
    body.side-nav-open .side-nav {
      transform: translateX(0);
    }
    .nav-overlay {
      display: block;
      pointer-events: none;
    }
  }
</style>
