---
// 提示块：info | warning | success | note
export interface Props {
  type?: 'info' | 'warning' | 'success' | 'note';
  title?: string;
}
const { type = 'info', title } = Astro.props;
const iconMap = { info: 'ℹ️', warning: '⚠️', success: '✅', note: '📝' };
const icon = iconMap[type] || 'ℹ️';
---
<aside class:list={['callout', `callout-${type}`]}>
  <div class="callout-icon" aria-hidden="true">{icon}</div>
  <div class="callout-body">
    {title && <strong class="callout-title">{title}</strong>}
    <slot />
  </div>
</aside>

<style>
  .callout {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    margin: 1.4rem 0;
    padding: 1rem 1.2rem;
    border-radius: var(--radius);
    background: var(--bg-elevated);
    border-left: 4px solid var(--border-color);
  }
  .callout-info { border-left-color: var(--callout-info); }
  .callout-warning { border-left-color: var(--callout-warning); }
  .callout-success { border-left-color: var(--callout-success); }
  .callout-note { border-left-color: var(--callout-note); }
  .callout-icon { font-size: 1.4rem; line-height: 1.5; }
  .callout-title { display: block; margin-bottom: 0.25em; color: var(--text-main); }
  .callout-body { color: var(--text-muted); font-size: 0.95em; line-height: 1.7; }
  .callout-body :global(p:first-child) { margin-top: 0; }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
