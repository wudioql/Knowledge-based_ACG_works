---
import { buildTocTree } from '../utils/toc';

export interface Props {
  headings: { depth: number; text: string; slug?: string }[];
  /** 标题 */
  title?: string;
  /** 显示模式（rail 用于宽屏侧栏；popover 用于窄屏弹出层） */
  mode?: 'rail' | 'popover';
}

const { headings = [], title = '本章目录', mode = 'rail' } = Astro.props;

type Node = { depth: number; text: string; slug: string; children: Node[] };
const root: Node[] = buildTocTree(headings);
---

<aside class:list={["toc-rail", "toc-rail-mode-" + mode]} role="navigation" aria-label={title}>
  <div class="toc-rail-header">{title}</div>
  {root.length > 0 ? (
    <ul class="toc-list">
      {root.map((node) => (
        <li class="toc-item" data-depth={node.depth}>
          <div class="toc-row">
            {node.children.length > 0 ? (
              <button type="button" class="toc-toggle" aria-expanded="false" aria-controls={`toc-${node.slug}`} aria-label={`展开 ${node.text}`}>
                <span class="toc-toggle-icon">▸</span>
              </button>
            ) : (
              <span class="toc-spacer" aria-hidden="true"></span>
            )}
            <a class="toc-link" href={`#${node.slug}`} data-target={`#${node.slug}`}>{node.text}</a>
          </div>
          {node.children.length > 0 && (
            <div class="toc-children" id={`toc-${node.slug}`} hidden>
              <ul class="toc-list">
                {node.children.map((child) => (
                  <li class="toc-item" data-depth={child.depth}>
                    <div class="toc-row">
                      <span class="toc-spacer" aria-hidden="true"></span>
                      <a class="toc-link" href={`#${child.slug}`} data-target={`#${child.slug}`}>{child.text}</a>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </li>
      ))}
    </ul>
  ) : (
    <p class="toc-empty">本章暂无小标题</p>
  )}
</aside>

<style>
  /* 组件内部仅维护与容器尺寸相关的细节，其余样式（颜色/滚动条/高亮/折叠过渡）均继承 theme.css 中的 .toc-rail 等公共样式 */
  .toc-rail {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 1rem 1rem 1.2rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    font-size: 0.9em;
    scrollbar-width: thin;
  }
  .toc-rail::-webkit-scrollbar { width: 6px; }
  .toc-rail::-webkit-scrollbar-track { background: transparent; }
  .toc-rail::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 999px;
  }
  .toc-rail::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }

  .toc-rail-header {
    font-weight: 700;
    color: var(--accent-primary);
    margin-bottom: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.78em;
  }
  .toc-empty {
    color: var(--text-muted);
    font-size: 0.9em;
    margin: 0.5rem 0 0;
  }
  /* 层级列表 */
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-children .toc-list {
    padding-left: 0.5rem;
    margin-top: 0.15rem;
    border-left: 1px dashed color-mix(in srgb, var(--border-color) 70%, transparent);
    margin-left: 0.55rem;
  }
  .toc-item { margin: 0.18em 0; }
  .toc-row {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem;
  }
  .toc-toggle,
  .toc-spacer {
    flex: 0 0 auto;
    width: 1.1rem;
    height: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .toc-toggle {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.7em;
    transition: color 0.15s ease;
  }
  .toc-toggle:hover { color: var(--accent-primary); }
  .toc-toggle-icon {
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .toc-toggle[aria-expanded="true"] .toc-toggle-icon {
    transform: rotate(90deg);
  }
  .toc-link {
    display: block;
    flex: 1 1 auto;
    padding: 0.3em 0.7em;
    border-left: 2px solid var(--border-color);
    color: var(--text-muted);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    transition: all 0.15s ease;
    line-height: 1.4;
  }
  .toc-link:hover {
    color: var(--accent-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--accent-primary) 6%, transparent);
  }
  .toc-children {
    padding-top: 0.1rem;
  }
  .toc-children[hidden] {
    display: none;
  }
</style>
